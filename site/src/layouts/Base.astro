---
import '../styles/base.css';
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0a0c10" />
    <meta name="google-site-verification" content="b78eA7vLP2pr1RajfLxqp5CVPkS_OfDPfu-YCfuzDZ4" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="d29e43b1-e2e8-4b77-8cdb-b91899ca8f55"></script>
  </head>
  <body>
    <main>
      <nav class="nav">
        <a href="/" class="logo">taskdev<span class="accent">.dev</span></a>
        <div class="links">
          <a href="https://github.com/tolbxela/taskdev">GitHub</a>
          <a href="https://marketplace.visualstudio.com/items?itemName=Tolbxela.taskdev">VS Code</a>
          <a href="https://open-vsx.org/extension/tolbxela/taskdev">Open VSX</a>
        </div>
      </nav>
      <slot />
    </main>
    <script is:inline>
      function track(name, props) {
        if (window.umami && typeof window.umami.track === 'function') {
          props ? window.umami.track(name, props) : window.umami.track(name);
        }
      }
      document.addEventListener('click', function (e) {
        var t = e.target;
        if (!t) return;
        var copyBtn = t.closest && t.closest('.install-cmd');
        if (copyBtn) {
          var cmd = copyBtn.textContent.trim();
          navigator.clipboard && navigator.clipboard.writeText(cmd).catch(function(){});
          copyBtn.classList.add('copied');
          setTimeout(function(){ copyBtn.classList.remove('copied'); }, 1200);
          track('install-cmd-copy', { cmd: cmd.length > 60 ? cmd.slice(0, 60) : cmd });
          return;
        }
        var a = t.closest && t.closest('a');
        if (!a) return;
        var href = a.getAttribute('href') || '';
        if (href.indexOf('http') !== 0) return;
        var host;
        try { host = new URL(href).hostname; } catch (_) { return; }
        if (host === location.hostname) return;
        if (host === 'marketplace.visualstudio.com') {
          track('install-click', { dest: 'vscode' });
        } else if (host === 'open-vsx.org') {
          track('install-click', { dest: 'ovsx' });
        } else if (host === 'github.com') {
          track('gh-click');
        } else if (host === 'medium.com' || host === 'dev.to') {
          track('writeup-click', { dest: host === 'medium.com' ? 'medium' : 'devto' });
        } else if (host === 'tolbxela.com') {
          track('author-click');
        } else {
          track('outbound-click', { host: host });
        }
      });
    </script>
  </body>
</html>
